@page "/welcome"
@layout EmptyLayout
@inject Frontend.Features.AuthService Auth
@inject NavigationManager Nav

<PageTitle>Welcome | WafCrypto — Next-Gen Trading</PageTitle>


<div class="welcome-page">
    <!-- Background decorative elements -->
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
    <div class="bg-grid"></div>

    <div class="welcome-card">
        <!-- Avatar -->
        <div class="avatar">
            @username.Substring(0, 1).ToUpper()
        </div>

        <!-- Greeting -->
        <div class="greeting">
            <span class="greeting-small">You're logged in as</span>
            <h1 class="greeting-name">@username</h1>
        </div>

        <!-- Status badge -->
        <div class="status-badge">
            <span class="status-dot"></span>
            <span>Active session</span>
        </div>

        <!-- Stats row -->
        <div class="stats-row">
            <div class="stat-item">
                <span class="stat-value">1</span>
                <span class="stat-label">Session</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-value">@DateTime.Now.ToString("HH:mm")</span>
                <span class="stat-label">Login Time</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-value">@DateTime.Now.ToString("dd MMM")</span>
                <span class="stat-label">Today</span>
            </div>
        </div>

        <!-- Logout button -->
        <button class="btn-logout" @onclick="Logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Sign Out
        </button>
    </div>
</div>

@code {
    string username = "";

    protected override async Task OnInitializedAsync()
    {
        var user = await Auth.GetCurrentUser(); // ← async
        username = user?.Username ?? "";
        if (string.IsNullOrEmpty(username))
            Nav.NavigateTo("/login");
    }

    async Task Logout()
    {
        await Auth.Logout();
        Nav.NavigateTo("/login");
    }
}
