@page "/"
@layout EmptyLayout


<PageTitle>WafCrypto — Next-Gen Trading</PageTitle>

<div class="home">

    <!-- NAV -->
    <nav class="nav">
        <div class="nav-logo">
            <svg viewBox="0 0 32 32" fill="none">
                <polygon points="16,2 30,9 30,23 16,30 2,23 2,9" fill="none" stroke="#f7931a" stroke-width="1.5"/>
                <polygon points="16,7 25,12 25,20 16,25 7,20 7,12" fill="rgba(247,147,26,0.1)" stroke="#f7931a" stroke-width="1"/>
                <circle cx="16" cy="16" r="3" fill="#f7931a"/>
            </svg>
            <span>WafCrypto</span>
        </div>
        <div class="nav-links">
            <a href="#">Markets</a>
            <a href="#">Trade</a>
            <a href="#">Portfolio</a>
            <a href="#">Learn</a>
        </div>
        <div class="nav-actions">
            <a href="/login" class="btn-ghost">Log In</a>
            <a href="/register" class="btn-primary">Get Started</a>
        </div>
    </nav>

    <!-- HERO -->
    <main>
    <section class="hero">
        <div class="hero-bg">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="grid-overlay"></div>
        </div>

        <div class="hero-content">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                Live Markets · 200+ Assets
            </div>
            <h1 class="hero-title">
                Trade Crypto<br/>
                <span class="hero-accent">Without Limits.</span>
            </h1>
            <p class="hero-sub">
                Institutional-grade execution. Real-time data. Zero compromise.
                The platform built for serious traders.
            </p>
            <div class="hero-cta">
                <a href="/register" class="btn-cta">Start Trading Free</a>
                <a href="#markets" class="btn-outline">View Markets →</a>
            </div>

            <!-- Fake stats -->
            <div class="hero-stats">
                <div class="stat">
                    <span class="stat-num">$48.2B</span>
                    <span class="stat-lbl">24h Volume</span>
                </div>
                <div class="stat-sep"></div>
                <div class="stat">
                    <span class="stat-num">3.4M+</span>
                    <span class="stat-lbl">Active Traders</span>
                </div>
                <div class="stat-sep"></div>
                <div class="stat">
                    <span class="stat-num">0.01%</span>
                    <span class="stat-lbl">Maker Fee</span>
                </div>
            </div>
        </div>

        <!-- Ticker tape -->
        <div class="ticker-wrap">
            <div class="ticker">
                @foreach (var coin in _coins)
                {
                <div class="ticker-item @(coin.Change > 0 ? "up" : "down")">
                    <span class="ticker-name">@coin.Symbol</span>
                    <span class="ticker-price">$@coin.Price.ToString("N2")</span>
                    <span class="ticker-change">@(coin.Change > 0 ? "+" : "")@coin.Change.ToString("F2")%</span>
                </div>
                }
                @* Duplicate for seamless loop *@
                @foreach (var coin in _coins)
                {
                <div class="ticker-item @(coin.Change > 0 ? "up" : "down")">
                    <span class="ticker-name">@coin.Symbol</span>
                    <span class="ticker-price">$@coin.Price.ToString("N2")</span>
                    <span class="ticker-change">@(coin.Change > 0 ? "+" : "")@coin.Change.ToString("F2")%</span>
                </div>
                }
            </div>
        </div>
    </section>

    <!-- MARKETS TABLE -->
    <section class="markets" id="markets">
        <div class="section-header">
            <h2>Top Markets</h2>
            <span class="section-badge">Live</span>
        </div>
        <div class="market-table">
            <div class="market-head">
                <span>#</span>
                <span>Asset</span>
                <span>Price</span>
                <span>24h Change</span>
                <span>Market Cap</span>
                <span></span>
            </div>
            @for (int i = 0; i < _coins.Count; i++)
            {
            var coin = _coins[i];
            var idx = i;
            <div class="market-row">
                <span class="row-rank">@(idx + 1)</span>
                <div class="row-asset">
                    <div class="coin-icon" style="background: @coin.Color">@coin.Symbol.Substring(0,1)</div>
                    <div>
                        <span class="coin-name">@coin.Name</span>
                        <span class="coin-sym">@coin.Symbol</span>
                    </div>
                </div>
                <span class="row-price">$@coin.Price.ToString("N2")</span>
                <span class="row-change @(coin.Change > 0 ? "up" : "down")">
                        @(coin.Change > 0 ? "▲" : "▼") @Math.Abs(coin.Change).ToString("F2")%
                    </span>
                <span class="row-cap">@coin.MarketCap</span>
                <button class="btn-trade">Trade</button>
            </div>
            }
        </div>
    </section>

    <!-- FEATURES -->
    <section class="features">
        <h2 class="features-title">Why CryptoX?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3>Ultra-Low Latency</h3>
                <p>Sub-millisecond order execution with co-located servers across 12 global data centers.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔐</div>
                <h3>Bank-Grade Security</h3>
                <p>Cold storage, multi-sig wallets, and 2FA protection for every account — always.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h3>Advanced Charting</h3>
                <p>TradingView-powered charts with 100+ indicators, custom layouts, and real-time alerts.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🌍</div>
                <h3>Global Liquidity</h3>
                <p>Deep order books aggregated from 50+ liquidity providers for best-in-class fills.</p>
            </div>
        </div>
    </section>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-logo">
            <svg viewBox="0 0 32 32" fill="none" width="24" height="24">
                <polygon points="16,2 30,9 30,23 16,30 2,23 2,9" stroke="#f7931a" stroke-width="1.5"/>
                <circle cx="16" cy="16" r="3" fill="#f7931a"/>
            </svg>
            WafCrypto
        </div>
        <p class="footer-copy">© 2026 WafCrypto. Not financial advice. Trade responsibly.</p>
    </footer>

</div>

@code {
record CoinData(string Symbol, string Name, double Price, double Change, string MarketCap, string Color);

List<CoinData> _coins = new()
{
new("BTC",  "Bitcoin",   67420.50,  +2.34, "$1.32T",  "#f7931a"),
new("ETH",  "Ethereum",   3512.80,  +1.87, "$422B",   "#627eea"),
new("BNB",  "BNB",         598.40,  -0.92, "$88B",    "#f3ba2f"),
new("SOL",  "Solana",      178.25,  +5.61, "$79B",    "#9945ff"),
new("XRP",  "XRP",           0.72,  -1.43, "$39B",    "#00aae4"),
new("ADA",  "Cardano",       0.61,  +0.78, "$21B",    "#0033ad"),
new("DOGE", "Dogecoin",      0.18,  +3.21, "$26B",    "#c2a633"),
new("AVAX", "Avalanche",    40.55,  -2.10, "$17B",    "#e84142"),
};
}

