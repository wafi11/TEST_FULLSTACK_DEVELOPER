@page "/register"
@layout AuthLayout
@inject Frontend.Features.AuthService Auth
@inject NavigationManager Nav

<PageTitle>Register | WafCrypto — Next-Gen Trading</PageTitle>


<div class="login-container">
    <h2 class="login-title">Create Account</h2>
    <p class="login-sub">Register to get started</p>

    @* Tambah ini buat nampilin error *@
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="error-box">
            <span>⚠️ @error</span>
        </div>
    }

    <div class="form-group">
        <label>Username</label>
        <div class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            <input
                class="form-input"
                type="text"
                placeholder="wafiuddin"
                @bind="username"
                @bind:event="oninput"
            />
        </div>
    </div>

    <div class="form-group">
        <label>Password</label>
        <div class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input
                class="form-input"
                type="@(showPassword ? "text" : "password")"
                placeholder="••••••••"
                @bind="password"
                @bind:event="oninput"
            />
            <button class="toggle-password" type="button" @onclick="HandleShowPassword">
                @if (showPassword)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                        <line x1="1" y1="1" x2="23" y2="23"/>
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                }
            </button>
        </div>
    </div>

    <button class="btn-register" @onclick="HandleRegister" disabled="@isLoading">
        @if (isLoading)
        {
            <span class="spinner"></span>
            <span>Submitting...</span>
        }
        else
        {
            <span>Sign Up</span>
        }
    </button>

    <p class="login-link">
        Already have an account? <a href="/login">Login</a>
    </p>
</div>


@code {
    string username = "", password = "", error = "";
    bool showPassword = false;
    bool isLoading = false;

    void HandleShowPassword()
    {
        showPassword = !showPassword;
    }

    async Task HandleRegister()
    {
        isLoading = true;
        error = "";

        var (success, err) = await Auth.Register(username, password);

        if (success)
        {
            Nav.NavigateTo("/login");
        }
        else
        {
            error = err;
        }

        isLoading = false;
    }
}
