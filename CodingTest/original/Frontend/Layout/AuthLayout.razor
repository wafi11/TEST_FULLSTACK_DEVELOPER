@inherits LayoutComponentBase

<div class="auth-page">
    
    <!-- Left Panel - Branding -->
    <div class="auth-left">
        <div class="brand">
            <div class="brand-logo">
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="20" cy="20" r="20" fill="#F7931A"/>
                    <path d="M25.5 17.2c.3-2-1.2-3.1-3.3-3.8l.7-2.7-1.6-.4-.6 2.6c-.4-.1-.9-.2-1.3-.3l.6-2.7-1.6-.4-.7 2.7c-.4-.1-.7-.2-1-.2v0l-2.2-.6-.4 1.8s1.2.3 1.2.3c.7.2.8.6.8.9l-.8 3.3c0 0 .1 0 .1 0l-.1 0-.7 2.8c-.1.2-.3.5-.7.4 0 .1-1.2-.3-1.2-.3l-.8 1.9 2.1.5c.4.1.8.2 1.2.3l-.7 2.7 1.6.4.7-2.7c.4.1.9.2 1.3.3l-.7 2.7 1.6.4.7-2.7c2.8.5 4.9.3 5.8-2.2.7-2-.03-3.2-1.5-3.9 1.1-.3 1.9-1 2.1-2.5zm-3.8 5.3c-.5 2-3.9.9-5 .6l.9-3.5c1.1.3 4.6.8 4.1 2.9zm.5-5.3c-.5 1.8-3.3.9-4.2.7l.8-3.2c.9.2 3.9.6 3.4 2.5z" 
                          fill="white"/>
                </svg>
            </div>
            <span class="brand-name">WafCrypto</span>
        </div>

        <div class="left-content">
            <h1 class="left-heading">
                Your assets.<br />
                <span class="accent">Fully sovereign.</span>
            </h1>
            <p class="left-sub">
                Trade, stake, and manage crypto across 50+ chains. Institutional-grade security, zero compromises.
            </p>

            <div class="features">
                <div class="feature-item">
                    <div class="feature-icon">₿</div>
                    <span>50+ blockchains supported</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">🔒</div>
                    <span>Non-custodial & self-sovereign</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">⚡</div>
                    <span>Real-time on-chain analytics</span>
                </div>
            </div>

            <div class="ticker-strip">
                <div class="ticker-track">
                    <span class="ticker-item up">BTC $97,420 <em>+2.4%</em></span>
                    <span class="ticker-item up">ETH $3,280 <em>+1.8%</em></span>
                    <span class="ticker-item down">SOL $182 <em>-0.6%</em></span>
                    <span class="ticker-item up">BNB $421 <em>+0.9%</em></span>
                    <span class="ticker-item up">ARB $1.24 <em>+3.1%</em></span>
                    <span class="ticker-item up">BTC $97,420 <em>+2.4%</em></span>
                    <span class="ticker-item up">ETH $3,280 <em>+1.8%</em></span>
                    <span class="ticker-item down">SOL $182 <em>-0.6%</em></span>
                    <span class="ticker-item up">BNB $421 <em>+0.9%</em></span>
                    <span class="ticker-item up">ARB $1.24 <em>+3.1%</em></span>
                </div>
            </div>
        </div>

        <!-- Grid overlay -->
        <div class="grid-overlay"></div>

        <!-- Decorative elements -->
        <div class="deco deco-1"></div>
        <div class="deco deco-2"></div>
        <div class="hex-ring"></div>
    </div>

    <!-- Right Panel - Auth Form -->
    <div class="auth-right">
        <div class="form-wrapper">
            @Body
        </div>
    </div>

</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>


